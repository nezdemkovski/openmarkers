{
  "name": "openmarkers",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.10",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev dev:api",
    "build": "turbo run build",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "turbo run format",
    "lint": "turbo run lint",
    "lint:fix": "oxlint --fix",
    "generate:schema": "bun scripts/generate-schema.ts",
    "db:sync-biomarkers": "bun packages/db/src/sync-biomarkers.ts",
    "biomarkers:sync": "bun scripts/generate-schema.ts && bun packages/db/src/sync-biomarkers.ts"
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "bun-types": "^1.3.11",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "turbo": "^2.8.20",
    "typescript": "6.0.2"
  }
}
