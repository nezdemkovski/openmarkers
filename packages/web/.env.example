# packages/web/.env — used by API server and Vite dev server
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
AUTH_BASE_URL=https://auth.nezdemkovski.cloud/openmarkers/api/auth
AUTH_JWKS_URL=https://auth.nezdemkovski.cloud/openmarkers/api/auth/.well-known/jwks.json
AUTH_JWT_ISSUER=https://auth.nezdemkovski.cloud/openmarkers
AUTH_JWT_AUDIENCE=openmarkers
VITE_AUTH_BASE_URL=https://auth.nezdemkovski.cloud/openmarkers/api/auth
OAUTH_SECRET=generate-with-openssl-rand-base64-32
