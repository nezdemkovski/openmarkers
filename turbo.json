{
  "$schema": "https://v2-8-15-canary-7.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "index.html", "vite.config.ts", "tsconfig.json", "tailwind.config.*", "package.json"],
      "outputs": ["dist/**"],
      "env": ["VITE_NEON_AUTH_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:api": {
      "env": ["DATABASE_URL", "NEON_AUTH_BASE_URL"],
      "cache": false,
      "persistent": true
    },
    "format": {}
  }
}
