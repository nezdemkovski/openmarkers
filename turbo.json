{
  "$schema": "https://v2-8-17.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": [
        "src/**",
        "index.html",
        "vite.config.ts",
        "tsconfig.json",
        "tailwind.config.*",
        "package.json"
      ],
      "outputs": ["dist/**"],
      "env": ["VITE_AUTH_BASE_URL"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "dev:api": {
      "env": [
        "DATABASE_URL",
        "AUTH_BASE_URL",
        "AUTH_JWKS_URL",
        "AUTH_JWT_ISSUER",
        "AUTH_JWT_AUDIENCE",
        "OAUTH_SECRET"
      ],
      "cache": false,
      "persistent": true
    },
    "format": {},
    "lint": {}
  }
}
